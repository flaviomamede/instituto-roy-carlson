{
  "buildCommand": "bash build.sh",
  "outputDirectory": ".",
  "cleanUrls": true,
  "functions": {
    "api/file/[slug].js": {
      "includeFiles": "api/_data/library/**"
    }
  },
  "redirects": [
    {
      "source": "/revista",
      "destination": "/revista/",
      "permanent": true
    },
    {
      "source": "/biblioteca",
      "destination": "/biblioteca/",
      "permanent": true
    },
    {
      "source": "/biblioteca/documento",
      "destination": "/biblioteca/documento/",
      "permanent": true
    },
    {
      "source": "/biblioteca/data/allowlist.json",
      "destination": "/404.html",
      "permanent": false
    },
    {
      "source": "/biblioteca/files/private/:path*",
      "destination": "/404.html",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.institutoroycarlson.org" }],
      "destination": "https://institutoroycarlson.org/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "instituto-roy-carlson.vercel.app" }],
      "destination": "https://institutoroycarlson.org/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/file/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "private, no-store" }
      ]
    },
    {
      "source": "/revista/leitura/revista.pdf",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    }
  ]
}
